                law3Title: "3. 第三定律",
                info3Desc: "利用「萬有引力提供向心力」，假設軌道為圓形 (軌道半長軸 <i>a</i> = 軌道半徑 <i>r</i>)，來推導出週期 <i>T</i> 與軌道半徑 <i>r</i> 的關係：",
                lblDerive1: "萬有引力 = 向心力",
                infoClose: "關閉"
            },
            en: {
                title: "Kepler's Laws of Planetary Motion",
                infoBtn: "Info",
                sun: "Sun",
                planet: "Planet",
                semiMajor: "Semi-major Axis <i>a</i>: ",
                eccentricity: "Eccentricity <i>e</i>: ",
                law1Desc: "Determines ellipse flatness (1st Law)",
                law3Desc: "Affects Orbital Period (3rd Law)",
                period: "Orbital Period <i>T</i>:",
                t2a3: "Ratio <i>T</i>²/<i>a</i>³ (<i>T</i>:yr, <i>a</i>:AU):",
                unitYear: "yr",
                toggleAreas: "Toggle Swept Areas (2nd Law)",
                toggleVectors: "Toggle Velocity & Acceleration Vectors",
                legendVel: "Velocity",
                legendAcc: "Acceleration",
                law2Desc: "Displays areas swept in equal time intervals.",
                simSpeed: "Simulation Speed",
                footer: "廠商會中學：物理科",
                infoTitle: "Kepler's Laws - HKDSE Formulas",
                preset: "Preset Object: ",
                presetCustom: "Custom",
                presetMercury: "Mercury",
                presetVenus: "Venus",
                presetEarth: "Earth",
                presetMars: "Mars",
                presetJupiter: "Jupiter",
                presetHalley: "Halley's Comet",
                law1Title: "1. Law of Ellipses",
                info1Desc: "In the HKDSE Core section, we often simplify planetary orbits as circular. In the Astronomy elective module, it is required to recognize that real orbits are elliptical, with the Sun located at one focus. The semi-major axis <i>a</i> can be found using the following formula:",
                law1Formula: "<div>$$a = \\frac{1}{2}(\\text{distance between perihelion and aphelion})$$</div>",
                law2Title: "2. Law of Equal Areas",
                info2Desc: "A planet sweeps out equal areas in equal times. Therefore, the planet moves fastest when closest to the Sun (perihelion) and slowest when farthest (aphelion).",
                law3Title: "3. Third Law",
                info3Desc: "Using 'Gravitational Force provides Centripetal Force' and assuming a circular orbit (semi-major axis <i>a</i> = orbital radius <i>r</i>), we derive the relationship between period <i>T</i> and orbital radius <i>r</i>:",
                lblDerive1: "Gravitational Force = Centripetal Force",
                infoClose: "Close"
