        };

        // State variable for current language
        let currentLang = 'zh';

        /**
         * Applies the selected language strings to the DOM elements.
         * Scans for the `data-i18n` attribute and updates innerHTML.
         */
        function applyLanguage() {
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (i18n[currentLang][key]) {
                    el.innerHTML = i18n[currentLang][key];
                }
            });
            // Re-run MathJax rendering if formulas were dynamically updated inside text
            if (window.MathJax) {
                MathJax.typesetPromise();
            }
        }

        /**
         * Toggles the application language between Traditional Chinese and English.
         */
        function toggleLanguage() {
            currentLang = currentLang === 'en' ? 'zh' : 'en';
            applyLanguage();
            updateUI(false); // Update the dynamic text units (e.g., "yr" vs "年") dynamically
        }

        document.getElementById('btn-lang').addEventListener('click', toggleLanguage);

        // ==========================================
        // 2. MODAL LOGIC (INFO PANEL)
        // ==========================================
        const modal = document.getElementById('info-modal');
        const modalContent = document.getElementById('info-modal-content');
        const btnInfo = document.getElementById('btn-info');
        const btnClose1 = document.getElementById('btn-close-modal');
        const btnClose2 = document.getElementById('btn-close-modal-bottom');

        /**
         * Opens the Info modal with a fade-in and scale-up animation.
         */
        function openModal() {
            modal.classList.remove('hidden');
            void modal.offsetWidth; // Trigger reflow to restart CSS transitions
            modal.classList.remove('opacity-0');
            modalContent.classList.remove('scale-95');
        }

        /**
         * Closes the Info modal with a fade-out and scale-down animation.
         */
        function closeModal() {
            modal.classList.add('opacity-0');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300); // Matches the duration-300 Tailwind class
        }

        btnInfo.addEventListener('click', openModal);
        btnClose1.addEventListener('click', closeModal);
        btnClose2.addEventListener('click', closeModal);
        
        // Close modal when clicking outside the content box
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });


        // ==========================================
        // 3. CANVAS SETUP & STATE MANAGEMENT
        // ==========================================
        const canvas = document.getElementById('simulationCanvas');
        const ctx = canvas.getContext('2d', { alpha: false }); // Disable alpha for rendering optimization
        
        let width, height;
        let BASE_SCALE = 100; // Pixels per Astronomical Unit (AU), updated dynamically

        // Core physics and simulation state parameters
        let params = {
            a: 1.0,      // Semi-major axis (AU)
            e: 0.017,    // Eccentricity (0 to <1)
            M: 0,        // Mean anomaly (Radians) - Represents theoretical time elapsed
            speed: 0.5,  // Simulation playback speed multiplier
            showAreas: false,   // Toggle for 2nd Law area visualization
            showVectors: false  // Toggle for Velocity/Acceleration vectors
        };

        // Cache DOM elements for quick updates
        const sliderA = document.getElementById('slider-a');
        const sliderE = document.getElementById('slider-e');
        const sliderSpeed = document.getElementById('slider-speed');
        const btnAreas = document.getElementById('btn-areas');
        const btnVectors = document.getElementById('btn-vectors');
        const presetSelect = document.getElementById('preset-select');
        
        const valA = document.getElementById('val-a');
        const valE = document.getElementById('val-e');
        const valT = document.getElementById('val-t');
        const valSpeed = document.getElementById('val-speed');

        // Preset celestial body orbital parameters (a in AU, e is dimensionless)
        const presets = {
            mercury: { a: 0.39, e: 0.206 },
            venus: { a: 0.72, e: 0.007 },
            earth: { a: 1.0, e: 0.017 },
            mars: { a: 1.52, e: 0.093 },
            jupiter: { a: 5.20, e: 0.048 },
            halley: { a: 17.8, e: 0.967 }
        };

        /**
         * Calculates the dynamic scaling factor (BASE_SCALE) to ensure the 
         * entire elliptical orbit always perfectly fits within the canvas bounds.
         */
        function updateScale() {
            if (!width || !height) return;
            
            // Calculate semi-minor axis (b) using b = a * sqrt(1 - e^2)
            const b = params.a * Math.sqrt(1 - params.e * params.e);
            
            // Scale dynamically to fit the exact bounding box of the ellipse (2a x 2b)
            // We use 40% (0.4) instead of 50% to leave a 10% safety margin around the canvas edges
            const scaleX = (width * 0.40) / params.a;
            const scaleY = (height * 0.40) / b;
            
            // The simulation scale is bound by whichever dimension (X or Y) is tighter
            BASE_SCALE = Math.min(scaleX, scaleY);
        }

        /**
         * Handles window resizing, adjusting canvas resolution for High-DPI (Retina) 
         * displays to keep the lines sharp, and triggers a scale update.
         */
        function resizeCanvas() {
            const rect = canvas.parentElement.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            canvas.width = rect.width * dpr;
            canvas.height = rect.height * dpr;
            ctx.scale(dpr, dpr);
            width = rect.width;
            height = rect.height;

            updateScale();
        }
        window.addEventListener('resize', resizeCanvas);
        

        // ==========================================
        // 4. PHYSICS ENGINE (KEPLER MATH UTILS)
        // ==========================================

        /**
         * Helper function to draw a directed arrow on the canvas for vectors.
         */
        function drawArrow(ctx, fromx, fromy, tox, toy, color) {
            const headlen = 10; // Length of the arrowhead in pixels
            const dx = tox - fromx;
            const dy = toy - fromy;
            const angle = Math.atan2(dy, dx);
            
            ctx.beginPath();
            ctx.moveTo(fromx, fromy);
            ctx.lineTo(tox, toy);
            ctx.strokeStyle = color;
            ctx.lineWidth = 2.5;
            ctx.stroke();
            
            ctx.beginPath();
            ctx.moveTo(tox, toy);
            ctx.lineTo(tox - headlen * Math.cos(angle - Math.PI / 6), toy - headlen * Math.sin(angle - Math.PI / 6));
            ctx.lineTo(tox - headlen * Math.cos(angle + Math.PI / 6), toy - headlen * Math.sin(angle + Math.PI / 6));
            ctx.lineTo(tox, toy);
            ctx.fillStyle = color;
            ctx.fill();
        }
        
        /**
         * Solves Kepler's Equation: M = E - e * sin(E)
         * Uses the Newton-Raphson iterative method to find the Eccentric Anomaly (E)
         * given the Mean Anomaly (M) and Eccentricity (e).
         * @param {number} M - Mean Anomaly (radians)
         * @param {number} e - Eccentricity
         * @returns {number} E - Eccentric Anomaly (radians)
         */
        function solveKepler(M, e) {
            let E = M; // Initial guess
            const tolerance = 1e-6; // Accuracy threshold
            for (let i = 0; i < 15; i++) {
                // Newton-Raphson adjustment step: f(E) / f'(E)
                let deltaE = (E - e * Math.sin(E) - M) / (1 - e * Math.cos(E));
                E -= deltaE;
                if (Math.abs(deltaE) < tolerance) break;
            }
            return E;
        }

        /**
         * Converts Eccentric Anomaly (E) to True Anomaly (theta).
         * True Anomaly is the actual physical angle of the planet from the perihelion.
         */
        function getTrueAnomaly(E, e) {
            return 2 * Math.atan2(
                Math.sqrt(1 + e) * Math.sin(E / 2),
                Math.sqrt(1 - e) * Math.cos(E / 2)
            );
        }

        /**
         * Calculates the (x, y) coordinates of the planet relative to the focus (Sun).
         * Uses the polar equation of an ellipse: r = a(1 - e^2) / (1 + e*cos(theta)).
         */
        function getOrbitalPosition(M, a, e) {
            let E = solveKepler(M, e);
            let theta = getTrueAnomaly(E, e);
            let r = (a * (1 - e * e)) / (1 + e * Math.cos(theta));
            return {
                x: r * Math.cos(theta) * BASE_SCALE,
                y: r * Math.sin(theta) * BASE_SCALE,
                r: r,
                theta: theta
            };
        }


        // ==========================================
        // 5. RENDER LOOP
        // ==========================================
        let lastTime = performance.now();

        /**
         * Main animation loop. Computes physics delta, clears canvas, 
         * and redraws all orbital elements at 60fps.
         */
        function draw() {
            const currentTime = performance.now();
            const dt = (currentTime - lastTime) / 1000; // Delta time in seconds
            lastTime = currentTime;

            // Clear background
            ctx.fillStyle = '#0f172a'; // Tailwind slate-950
            ctx.fillRect(0, 0, width, height);

            ctx.save();
            
            // Offset the focal point (Sun) so the geometric *center* of the ellipse 
            // sits exactly at the screen center. The center of an ellipse is located 
            // at distance `a*e` from the focus along the major axis.
            const focusOffsetX = params.a * params.e * BASE_SCALE;
            ctx.translate((width / 2) + focusOffsetX, height / 2);

            // Calculate Mean Motion (n) using Kepler's Third Law (T^2 = a^3)
            const T = Math.pow(params.a, 1.5);
            const n = (2 * Math.PI) / T; // Angular velocity of Mean Anomaly
            
            // Advance the simulation time (Mean anomaly)
            params.M += n * dt * params.speed;
            params.M %= (2 * Math.PI); // Keep bounded between 0 and 2PI

            // --- 5.1 Draw Orbit Path ---
            // Smooth Fix: We iterate by Eccentric Anomaly (E) to guarantee uniform 
            // spatial spacing of line segments, preventing jagged polygons near perihelion.
            ctx.beginPath();
            ctx.strokeStyle = 'rgba(148, 163, 184, 0.4)';
            ctx.lineWidth = 1.5;
            
            const pathResolution = 300; // Number of segments making up the ellipse
            const b = params.a * Math.sqrt(1 - params.e * params.e);
            for (let i = 0; i <= pathResolution; i++) {
                const E_val = (i / pathResolution) * 2 * Math.PI;
                // Cartesian coordinates relative to the focus (Sun)
                const x = params.a * (Math.cos(E_val) - params.e) * BASE_SCALE;
                const y = b * Math.sin(E_val) * BASE_SCALE;
                
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.stroke();

            // --- 5.2 Draw Swept Areas (2nd Law) ---
            if (params.showAreas) {
                const numSectors = 8; // Divide orbit into 8 equal TIME sectors (Mean Anomaly)
                const sectorSizeM = (2 * Math.PI) / numSectors;

                for (let s = 0; s < numSectors; s++) {
                    const startM = s * sectorSizeM;
                    const endM = (s + 1) * sectorSizeM;
                    
                    ctx.beginPath();
                    ctx.moveTo(0, 0); // Ray starts from focus (Sun)
                    
                    // High resolution (150) for smooth colored arcs, particularly near perihelion
                    const arcResolution = 150;
                    for(let i=0; i<=arcResolution; i++) {
                        let m = startM + (i / arcResolution) * (endM - startM);
                        let pos = getOrbitalPosition(m, params.a, params.e);
                        ctx.lineTo(pos.x, pos.y);
                    }
                    ctx.lineTo(0, 0); // Close shape back to focus

                    // Alternate sector colors for visibility
                    if (s % 2 === 0) {
                        ctx.fillStyle = 'rgba(59, 130, 246, 0.2)'; // Blue tint
                    } else {
                        ctx.fillStyle = 'rgba(99, 102, 241, 0.25)'; // Indigo tint
                    }
                    ctx.fill();
                    ctx.strokeStyle = 'rgba(148, 163, 184, 0.3)';
                    ctx.stroke();
                }
                
                // Highlight the specific time sector the planet is currently travelling inside
                const currentSector = Math.floor(params.M / sectorSizeM);
                const hlStartM = currentSector * sectorSizeM;
                const hlEndM = params.M;
                
                ctx.beginPath();
                ctx.moveTo(0, 0);
                
                // Dynamic yellow highlight arc filling up as time progresses
                const hlResolution = 50;
                for(let i=0; i<=hlResolution; i++) {
                    let m = hlStartM + (i / hlResolution) * (hlEndM - hlStartM);
                    let pos = getOrbitalPosition(m, params.a, params.e);
                    ctx.lineTo(pos.x, pos.y);
                }
                ctx.lineTo(0,0);
                ctx.fillStyle = 'rgba(234, 179, 8, 0.4)';
                ctx.fill();
            }

            // --- 5.3 Draw Sun (Focus) ---
            ctx.beginPath();
            // Scale sun dynamically but clamp it so it doesn't get ridiculously huge/tiny
            const sunRadius = Math.min(Math.max(6, 15 * (BASE_SCALE/100)), 25);
            ctx.arc(0, 0, sunRadius, 0, 2 * Math.PI);
            ctx.fillStyle = '#facc15';
            ctx.shadowColor = '#facc15';
            ctx.shadowBlur = 20;
            ctx.fill();
            ctx.shadowBlur = 0;

            // --- 5.4 Draw Planet ---
            const planetPos = getOrbitalPosition(params.M, params.a, params.e);
            ctx.beginPath();
            // Scale planet dynamically but clamp it
            const planetRadius = Math.min(Math.max(4, 8 * (BASE_SCALE/100)), 12);
            ctx.arc(planetPos.x, planetPos.y, planetRadius, 0, 2 * Math.PI);
            ctx.fillStyle = '#60a5fa';
            ctx.shadowColor = '#60a5fa';
            ctx.shadowBlur = 15;
            ctx.fill();
            ctx.shadowBlur = 0;

            // Draw connecting line from Sun to Planet
            ctx.beginPath();
            ctx.moveTo(0, 0);
            ctx.lineTo(planetPos.x, planetPos.y);
            ctx.strokeStyle = 'rgba(96, 165, 250, 0.5)';
            ctx.setLineDash([5, 5]);
            ctx.stroke();
            ctx.setLineDash([]);

            // --- 5.5 Draw Velocity & Acceleration Vectors ---
            if (params.showVectors) {
                // To get velocity, we take the time derivative of the positional vectors.
                const E = solveKepler(params.M, params.e);
                const E_dot = n / (1 - params.e * Math.cos(E)); // Derivative of Kepler's Equation
                
                // Cartesian components of planet position relative to focus (in AU)
                const x_au = params.a * (Math.cos(E) - params.e);
                const y_au = params.a * Math.sqrt(1 - params.e * params.e) * Math.sin(E);
                
                // Velocity in AU/yr
                const vx = -params.a * Math.sin(E) * E_dot;
                const vy = params.a * Math.sqrt(1 - params.e * params.e) * Math.cos(E) * E_dot;
                
                // Acceleration in AU/yr^2 (Gravitational Parameter GM = 4*pi^2 in these units)
                const GM = 4 * Math.PI * Math.PI;
                const r_mag = Math.sqrt(x_au * x_au + y_au * y_au);
                const ax = -(GM / (r_mag * r_mag)) * (x_au / r_mag);
                const ay = -(GM / (r_mag * r_mag)) * (y_au / r_mag);
                
                // Dynamic Auto-Scaling for Vectors: 
                // We calculate theoretical maximums for the current orbit to normalize vector lengths.
                const rp = params.a * (1 - params.e); // Perihelion distance
                const v_max = Math.sqrt(GM * (2 / rp - 1 / params.a)); // Max velocity (vis-viva eq at perihelion)
                const a_max = GM / (rp * rp); // Max acceleration (Newton's Law at perihelion)

                // Set maximum visual length of arrows to 25% of the smaller screen dimension
                const max_arrow_px = Math.min(width, height) * 0.25;

                // Create constant scale factors for THIS specific planet setup 
                // Ensures vectors don't overflow the screen, but relative lengths are maintained within the orbit.
                const v_scale = max_arrow_px / v_max;
                const a_scale = max_arrow_px / a_max;
                
                let vx_vis = vx * v_scale;
                let vy_vis = vy * v_scale;
                let ax_vis = ax * a_scale;
                let ay_vis = ay * a_scale;
                
                // Enforce a minimum pixel length (15px) just to ensure the arrowhead is always 
                // visible even at extreme aphelions where velocity approaches zero.
                const min_arrow_px = 15;
                const v_vis_mag = Math.sqrt(vx_vis * vx_vis + vy_vis * vy_vis);
                const a_vis_mag = Math.sqrt(ax_vis * ax_vis + ay_vis * ay_vis);
                
                if (v_vis_mag > 0 && v_vis_mag < min_arrow_px) {
                    vx_vis *= min_arrow_px / v_vis_mag;
                    vy_vis *= min_arrow_px / v_vis_mag;
                }
                
                if (a_vis_mag > 0 && a_vis_mag < min_arrow_px) {
                    ax_vis *= min_arrow_px / a_vis_mag;
                    ay_vis *= min_arrow_px / a_vis_mag;
                }

                // Render the arrows on canvas
                drawArrow(ctx, planetPos.x, planetPos.y, planetPos.x + vx_vis, planetPos.y + vy_vis, '#22c55e'); // Green Velocity
                drawArrow(ctx, planetPos.x, planetPos.y, planetPos.x + ax_vis, planetPos.y + ay_vis, '#ef4444'); // Red Acceleration
            }

            ctx.restore();

            // Loop
            requestAnimationFrame(draw);
        }

        // ==========================================
        // 6. EVENT LISTENERS & UI UPDATES
        // ==========================================
        
        /**
         * Reads DOM inputs, updates physics `params`, recalculates calculated values (T),
         * and updates UI text. Also triggers a canvas scale update.
         * @param {boolean} fromSlider - True if triggered by a manual slider drag
         */
        function updateUI(fromSlider = false) {
            if (fromSlider) {
                presetSelect.value = 'custom'; // Switch dropdown to 'Custom' if user drags sliders
            }
            params.a = parseFloat(sliderA.value);
            params.e = parseFloat(sliderE.value);
            params.speed = parseFloat(sliderSpeed.value);
            
            valA.textContent = params.a.toFixed(2) + " AU";
            valE.textContent = params.e.toFixed(3);
            valSpeed.textContent = params.speed.toFixed(1) + "x";
            
            // Calculate orbital period (3rd Law: T^2 = a^3 -> T = a^1.5)
            const T = Math.pow(params.a, 1.5);
            const unit = i18n[currentLang].unitYear || 'yr';
            valT.textContent = T.toFixed(2) + " " + unit;

            updateScale();
        }

        // Bind slider events
        sliderA.addEventListener('input', () => updateUI(true));
        sliderE.addEventListener('input', () => updateUI(true));
        sliderSpeed.addEventListener('input', () => updateUI(false));

        // Preset dropdown logic
        presetSelect.addEventListener('change', (e) => {
            const val = e.target.value;
            if (presets[val]) {
                sliderA.value = presets[val].a;
                sliderE.value = presets[val].e;
                updateUI(false);
            }
        });

        // Toggle button logic for 2nd Law Areas
        btnAreas.addEventListener('click', () => {
            params.showAreas = !params.showAreas;
            if (params.showAreas) {
                // Active state styling
                btnAreas.classList.replace('bg-indigo-600', 'bg-emerald-600');
                btnAreas.classList.replace('hover:bg-indigo-500', 'hover:bg-emerald-500');
                btnAreas.classList.replace('shadow-indigo-500/20', 'shadow-emerald-500/20');
            } else {
                // Inactive state styling
                btnAreas.classList.replace('bg-emerald-600', 'bg-indigo-600');
                btnAreas.classList.replace('hover:bg-emerald-500', 'hover:bg-indigo-500');
                btnAreas.classList.replace('shadow-emerald-500/20', 'shadow-indigo-500/20');
            }
        });

        // Toggle button logic for Vectors
        btnVectors.addEventListener('click', () => {
            params.showVectors = !params.showVectors;
            const legend = document.getElementById('legend-vectors');
            if (params.showVectors) {
                // Active state styling
                btnVectors.classList.replace('bg-slate-700', 'bg-slate-600');
                btnVectors.classList.add('border-green-500', 'text-green-400');
                legend.classList.remove('hidden');
            } else {
                // Inactive state styling
                btnVectors.classList.replace('bg-slate-600', 'bg-slate-700');
                btnVectors.classList.remove('border-green-500', 'text-green-400');
                legend.classList.add('hidden');
            }
        });

        // Initialize application on load
        window.onload = () => {
            applyLanguage();
            resizeCanvas();
            updateUI();
            requestAnimationFrame(draw);
        };

    </script>
</body>
</html>
