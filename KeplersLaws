                semiMajor: "軌道半長軸 <i>a</i>：",
                eccentricity: "軌道離心率 <i>e</i>：",
                law1Desc: "決定橢圓的扁平程度 (第一定律)",
                law3Desc: "影響行星公轉週期 (第三定律)",
                period: "公轉週期 <i>T</i>：",
                t2a3: "比值 <i>T</i>²/<i>a</i>³ (<i>T</i>:年, <i>a</i>:AU)：",
                unitYear: "年",
                toggleAreas: "顯示掃過面積 (第二定律)",
                toggleVectors: "顯示速度與加速度向量",
